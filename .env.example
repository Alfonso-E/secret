# Copy this file to `.env` (without `.example`) and fill in your own values.
# The real `.env` should NEVER be shared, committed, or pasted anywhere.

# Which Bitget environment to talk to.
#   "demo"    -> production base URL + header `paptrading: 1`  (virtual funds, real prices)
#   "live"    -> production base URL, no demo header           (REAL MONEY — last step only)
BITGET_ENV=demo

# Bitget API credentials.
# Generate at: https://www.bitget.com/account/newapi  (Live)
#   or under: User Center -> Demo Trading -> API     (Demo)
# Required scope: Read + Trade. NEVER enable Withdraw for a bot key.
BITGET_API_KEY=your_api_key_here
BITGET_API_SECRET=your_api_secret_here

# Bitget REQUIRES a passphrase you set when creating the key.
# This is a third secret, distinct from the secret key. Both are needed for signing.
BITGET_API_PASSPHRASE=your_api_passphrase_here

# Optional: lock down which IP can use this key (Bitget-side restriction is even better).
# BITGET_ALLOWED_IP=1.2.3.4
